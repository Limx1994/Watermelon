{
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "read_file",
        "description": "读取文件内容，支持文本/图片/PDF/Notebook。返回结构化结果含metadata。",
        "parameters": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "文件路径（绝对路径或相对于项目根目录）"
            },
            "offset": {
              "type": "number",
              "description": "起始行号（从0开始，仅对文本文件有效）",
              "default": 0
            },
            "limit": {
              "type": "number",
              "description": "读取行数（仅对文本文件有效）"
            },
            "pages": {
              "type": "string",
              "description": "PDF页码范围，如 '1-5'（仅对PDF有效）"
            }
          },
          "required": [
            "path"
          ]
        },
        "command": "external_tools/read_file/dist/read_file.exe"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "write_file",
        "description": "写入文件内容到项目目录。独立的外部工具。",
        "parameters": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "文件路径（相对于项目根目录）"
            },
            "content": {
              "type": "string",
              "description": "写入文件的内容"
            }
          },
          "required": [
            "path",
            "content"
          ]
        },
        "command": "external_tools/write_file/dist/write_file.exe"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "shell",
        "description": "执行 PowerShell 命令（白名单验证）。",
        "parameters": {
          "type": "object",
          "properties": {
            "command": {
              "type": "string",
              "description": "要执行的 PowerShell 命令"
            }
          },
          "required": [
            "command"
          ]
        },
        "command": "external_tools/winshell/dist/winshell.exe"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "grep",
        "description": "搜索文件内容中的文本模式。",
        "command": "external_tools/grep/dist/grep.exe",
        "parameters": {
          "type": "object",
          "properties": {
            "pattern": {
              "type": "string",
              "description": "要搜索的正则表达式或文本"
            },
            "path": {
              "type": "string",
              "description": "搜索的目录路径（默认项目根目录）",
              "default": "."
            },
            "glob": {
              "type": "string",
              "description": "glob 模式过滤文件（如 *.py, *.{js,ts}）"
            },
            "output_mode": {
              "type": "string",
              "enum": ["content", "files_with_matches", "count"],
              "description": "输出模式：content（默认）、files_with_matches、count",
              "default": "content"
            },
            "B": {
              "type": "number",
              "description": "显示匹配前的行数"
            },
            "A": {
              "type": "number",
              "description": "显示匹配后的行数"
            },
            "C": {
              "type": "number",
              "description": "上下文行数（前后各显示 N 行）"
            },
            "context": {
              "type": "number",
              "description": "-C 的别名"
            },
            "n": {
              "type": "boolean",
              "description": "显示行号，默认 true",
              "default": true
            },
            "i": {
              "type": "boolean",
              "description": "大小写不敏感搜索"
            },
            "type": {
              "type": "string",
              "description": "按文件类型过滤（如 js, py, rust）"
            },
            "head_limit": {
              "type": "number",
              "description": "限制结果数，默认 250，0=无限制",
              "default": 250
            },
            "offset": {
              "type": "number",
              "description": "跳过前 N 个结果"
            },
            "multiline": {
              "type": "boolean",
              "description": "启用多行模式（. 匹配换行符）"
            },
            "recursive": {
              "type": "boolean",
              "description": "是否递归搜索",
              "default": true
            }
          },
          "required": [
            "pattern"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "glob",
        "description": "根据文件名模式查找文件。",
        "command": "external_tools/glob/dist/glob.exe",
        "parameters": {
          "type": "object",
          "properties": {
            "pattern": {
              "type": "string",
              "description": "文件名模式，如 *.py"
            },
            "path": {
              "type": "string",
              "description": "搜索的目录路径（默认项目根目录）"
            }
          },
          "required": [
            "pattern"
          ]
        }
      }
    }
  ]
}