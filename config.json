{
  "openai": {
    "api_key": "sk-*********************",
    "base_url": "https://api.deepseek.com",
    "model": "deepseek-v4-flash",
    "temperature": 0.7,
    "top_p": 0.7,
    "reasoning_effort": "max",
    "context_window": 1000
  },
  "agent": {
    "max_turns": 10,
    "max_retries": 3,
    "memory_threshold": 20,
    "thinking_enabled": true
  },
  "display": {
    "show_thinking": true,
    "thinking_indicator": "思考中"
  },
  "system_prompt": {
    "path": "./systsc.md"
  },
  "tools": {
    "enabled": ["shell", "file", "grep", "glob"]
  },
  "memory": {
    "path": "./memory/conversation.json",
    "auto_summary": true
  },
  "logs": {
    "path": "./logs/agent.log",
    "level": "INFO",
    "max_bytes": 10485760,
    "backup_count": 5
  }
}
