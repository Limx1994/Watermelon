{
  "openai": {
    "api_key": "sk-743aa9387b2c5",
    "base_url": "https://api.deepseek.com",
    "model": "deepseek-v4-flash",
    "fallback_model": "",
    "temperature": 0.7,
    "top_p": 0.7,
    "reasoning_effort": "max",
    "context_window": 128,
    "max_output_tokens": 20000
  },
  "agent": {
    "max_turns": 50,
    "max_retries": 3,
    "network_max_retries": 10,
    "network_retry_interval_seconds": 30,
    "nudge_threshold": 0.90
  },
  "compact": {
    "enabled": true,
    "buffer_tokens": 13000,
    "micro_compact_streak": 3,
    "micro_compact_gap_minutes": 5,
    "auto_compact_threshold": 0.85,
    "full_compact_threshold": 0.95,
    "preserve_recent_messages": 10
  },
  "display": {
    "show_thinking": true,
    "thinking_indicator": "思考中"
  },
  "tools": {
    "enabled": ["shell", "read_file", "write_file", "grep", "glob", "edit"]
  },
  "persistent_memory": {
    "enabled": true,
    "global_dir": "./global_memory",
    "max_index_chars": 4000,
    "types": ["user", "feedback", "project", "reference"]
  },
  "logs": {
    "path": "./logs/agent.log",
    "level": "INFO",
    "max_bytes": 10485760,
    "backup_count": 5
  },
  "prompts": {
    "system_intro": "./prompts/intro.md",
    "system_rules": "./prompts/system_rules.md",
    "system_doing_tasks": "./prompts/doing_tasks.md",
    "system_tool_usage": "./prompts/tool_usage.md",
    "system_tone_style": "./prompts/tone_style.md",
    "system_output_efficiency": "./prompts/output_efficiency.md",
    "autonomous_instructions": "./prompts/instructions.md",
    "compact_resume": "./prompts/compact_resume.md",
    "summary_system": "./prompts/summary_system.md",
    "summary_template": "./prompts/summary_template.md",
    "max_tokens_recovery": "./prompts/max_tokens_recovery.md",
    "context_too_long": "./prompts/context_too_long.md",
    "token_budget_nudge": "./prompts/token_budget_nudge.md"
  },
  "autonomous": {
    "tick_interval_minutes": 10,
    "cron_tasks": []
  }
}
