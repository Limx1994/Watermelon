{
  "openai": {
    "api_key": "sk-*********************",
    "base_url": "https://api.deepseek.com",
    "model": "deepseek-v4-flash",
    "temperature": 0.7,
    "top_p": 0.7,
    "reasoning_effort": "max",
    "context_window": 128,
    "max_output_tokens": 20000
  },
  "agent": {
    "max_turns": 10,
    "max_retries": 3,
    "memory_threshold": 20,
    "thinking_enabled": true
  },
  "compact": {
    "enabled": true,
    "prompt_path": "./compact_prompt.md",
    "buffer_tokens": 13000,
    "micro_compact_streak": 3,
    "micro_compact_gap_minutes": 5,
    "auto_compact_threshold": 0.85,
    "full_compact_threshold": 0.95,
    "preserve_recent_messages": 10
  },
  "display": {
    "show_thinking": true,
    "thinking_indicator": "思考中"
  },
  "system_prompt": {
    "path": "./systsc.md"
  },
  "tools": {
    "enabled": ["shell", "read_file", "write_file", "grep", "glob", "edit"]
  },
  "memory": {
    "path": "./memory/conversation.json",
    "auto_summary": true
  },
  "logs": {
    "path": "./logs/agent.log",
    "level": "INFO",
    "max_bytes": 10485760,
    "backup_count": 5
  }
}