{
  "openai": {
    "api_key": "your-api-key-here",
    "base_url": "https://api.deepseek.com",
    "model": "deepseek-v4-flash",
    "fallback_model": "",
    "temperature": 0.7,
    "top_p": 0.7,
    "reasoning_effort": "max",
    "context_window": 128,
    "max_output_tokens": 20000
  },
  "agent": {
    "max_turns": 50,
    "max_retries": 3,
    "network_max_retries": 10,
    "network_retry_interval_seconds": 30,
    "nudge_threshold": 0.90
  },
  "compact": {
    "enabled": true,
    "buffer_tokens": 13000,
    "micro_compact_streak": 3,
    "micro_compact_gap_minutes": 5,
    "auto_compact_threshold": 0.85,
    "full_compact_threshold": 0.95,
    "preserve_recent_messages": 10
  },
  "display": {
    "show_thinking": true,
    "thinking_indicator": "思考中"
  },
  "tools": {
    "enabled": ["shell", "read_file", "write_file", "grep", "glob", "edit"]
  },
  "persistent_memory": {
    "enabled": true,
    "global_dir": "",
    "max_index_chars": 4000,
    "types": ["user", "feedback", "project", "reference"]
  },
  "logs": {
    "path": "./logs/agent.log",
    "level": "INFO",
    "max_bytes": 10485760,
    "backup_count": 5
  },
  "prompts": {
    "system_intro": "./prompts/system/intro.md",
    "system_rules": "./prompts/system/system_rules.md",
    "system_doing_tasks": "./prompts/system/doing_tasks.md",
    "system_tool_usage": "./prompts/system/tool_usage.md",
    "system_tone_style": "./prompts/system/tone_style.md",
    "system_output_efficiency": "./prompts/system/output_efficiency.md",
    "autonomous_instructions": "./prompts/autonomous/instructions.md",
    "compact_resume": "./prompts/service/compact_resume.md",
    "summary_system": "./prompts/service/summary_system.md",
    "summary_template": "./prompts/service/summary_template.md",
    "max_tokens_recovery": "./prompts/recovery/max_tokens_recovery.md",
    "context_too_long": "./prompts/recovery/context_too_long.md",
    "token_budget_nudge": "./prompts/recovery/token_budget_nudge.md"
  },
  "autonomous": {
    "tick_interval_minutes": 10,
    "cron_tasks": []
  }
}
